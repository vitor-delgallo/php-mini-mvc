# ========================
# 🌐 Application Environment
# ========================

# Defines the current application environment: development | testing | production
APP_ENV=development

# Base path if the app is running in a subdirectory (e.g. /myapp)
BASE_PATH=/php-mini-mvc

# Default language used by the application (e.g. en, pt-br)
DEFAULT_LANGUAGE=en

# App helpers autoload strategy:
# - true: loads all helpers inside app/helpers (default)
# - ['my_helper','other_helper.php']: loads only listed helpers (with or without .php)
APP_HELPERS_AUTOLOAD=true

# Not currently used by the framework core, but useful when working with encrypted files or sensitive texts.
# If you are interested, check the Security class from: vitor-delgallo/PHPHelper
APP_KEY=

# ========================
# 🧠 Sessions
# ========================

# Session driver: files | db | none
# - files: uses native PHP file-based sessions
# - db: stores session data in the database
# - none: disables session handling
SESSION_DRIVER=none

# Optional prefix for session keys (used when SESSION_DRIVER=db)
SESSION_PREFIX=

# Encryption key for securing session data (used when SESSION_DRIVER=db)
SESSION_ENCRYPT_KEY=

# ========================
# 🗄️ Database
# ========================

# Database driver: mysql | pgsql | none
DB_DRIVER=none

# Database host (e.g. localhost, 127.0.0.1)
DB_HOST=

# Database port (leave blank to use the default port for the selected driver)
DB_PORT=

# Name of the database to connect to
DB_NAME=

# Username for database authentication
DB_USER=

# Password for the specified database user
DB_PASS=

# Charset used in the database connection (e.g. utf8, utf8mb4)
DB_CHARSET=utf8
